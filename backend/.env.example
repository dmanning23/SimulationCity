# App
SECRET_KEY=change-me-in-production-use-a-long-random-string
ENVIRONMENT=development

# MongoDB — use Atlas connection string (replica set required for Phase 3 change streams)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URL=TODO
MONGODB_DB_NAME=simulationcity

# Redis (local docker-compose)
REDIS_URL=redis://localhost:6379/0

# JWT
# JWT_EXPIRE_MINUTES=1440  # 24 hours (default)

# Feature flags
ENABLE_SD_GENERATION=false

# AWS S3 — premium only, leave empty for local dev
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=simulationcity-assets
# AWS_REGION=us-east-1

# Replicate — premium only, leave empty for local dev
# REPLICATE_API_TOKEN=
